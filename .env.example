# ─── Spotify Integration ───────────────────────────────────────────────────────
# Obtain from: https://developer.spotify.com/dashboard
# Required for: Spotify playlist browsing, track search, and playback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ─── Apple Music Integration ───────────────────────────────────────────────────
# Obtain from: https://developer.apple.com (requires $99/yr Apple Developer membership)
# Required for: Apple Music library browsing and MusicKit JS playback
APPLE_TEAM_ID=your_10_char_apple_team_id
APPLE_KEY_ID=your_apple_musickit_key_id
# Paste the FULL content of your .p8 private key file (replace newlines with \n)
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----

# ─── YouTube Integration ───────────────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com (YouTube Data API v3)
# Free tier: 10,000 units/day (~100 search queries)
# Required for: YouTube video search and embedded playback
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# ─── SoundCloud Integration ────────────────────────────────────────────────────
# Apply for access at: https://developers.soundcloud.com
# Required for: SoundCloud OAuth, liked tracks, playlists, and DJ-friendly discovery
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret

# ─── Other App Secrets ─────────────────────────────────────────────────────────
# Admin dashboard access key
ADMIN_KEY=your_secure_admin_key

# OpenAI API key (managed via Replit AI Integrations)
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
