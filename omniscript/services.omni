draw { Nova } from "nova:std"
draw { Signal, Status, Priority, Timestamp, Duration } from "nova:std/types"
draw { Service, RequestContext, QueryFilter } from "nova:std/service"
draw { DataVault } from "nova:std/data"


/// OpenAI-powered AI DJ assistant for setlist planning and transition guidance
@service(
  id: "aidj-svc",
  platform: "NovaMusic",
  shield: ShieldLevel.MAXIMUM
)
service AIDJService {

  @inject forge vault: DataVault<Any>
  @inject forge auth: Nova.Auth
  @inject forge bus: Nova.Bus

  @portal(endpoint: "novamusic.aidj.get")
  @shield(require: ["AUTHENTICATED"])
  @validate(schema: StandardRequestSchema)
  manifest getAll(
    ctx:    RequestContext,
    filter: QueryFilter?
  ): flow<Constellation<Any>> {
    forge identity = sync this.auth.verify(ctx)

    forge results = sync this.vault.query({
      owner:  identity.userId,
      filter: filter ?? QueryFilter.none(),
      limit:  100
    })

    Nova.Metrics.pulse("novamusic.aidjservice.get", 1.0)
    propagate results
  }

  @portal(endpoint: "novamusic.aidj.create")
  @audit
  @shield(require: ["AUTHENTICATED"])
  @validate(schema: CreateRequestSchema)
  manifest create(
    input: Any,
    ctx:   RequestContext
  ): flow<Any> {
    forge identity = sync this.auth.verify(ctx)

    forge entry = sync this.vault.store({
      ...input,
      id:        Nova.Crypto.uuid(),
      ownerId:   identity.userId,
      createdAt: Timestamp.now(),
      status:    Status.ACTIVE
    })

    // Broadcast creation signal via IDB
    Nova.Bus.emit("novamusic.aidj.created", Signal {
      topic:   "novamusic.aidj.created",
      payload: { entryId: entry.id, userId: identity.userId },
      origin:  "novamusic",
      priority: Priority.NORMAL
    })

    Nova.Metrics.pulse("novamusic.aidjservice.create", 1.0)
    propagate entry
  }

  @portal(endpoint: "novamusic.aidj.update")
  @audit
  @shield(require: ["AUTHENTICATED", "OWNS_RESOURCE"])
  manifest update(
    id:    Text,
    input: Any,
    ctx:   RequestContext
  ): flow<Any> {
    forge identity = sync this.auth.verify(ctx)
    forge existing = sync this.vault.get(id)
    when (existing == nil) {
      fault ResourceNotFound { resource: "AIDJ", id }
    }

    forge updated = sync this.vault.update(id, {
      ...input,
      updatedAt: Timestamp.now(),
      updatedBy: identity.userId
    })

    propagate updated
  }

  @portal(endpoint: "novamusic.aidj.delete")
  @audit
  @shield(require: ["AUTHENTICATED", "OWNS_RESOURCE"])
  manifest dissolve(id: Text, ctx: RequestContext): flow<nil> {
    forge identity = sync this.auth.verify(ctx)
    sync this.vault.softDelete(id, identity.userId)
    Nova.Metrics.pulse("novamusic.aidjservice.delete", 1.0)
    propagate nil
  }
}

